# Пример переменных окружения для Vercel
# Эти переменные нужно добавить в Settings → Environment Variables

# Токен бота от @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ID администратора (ваш Telegram ID)
ADMIN_CHAT_ID=123456789

# URL вашего деплоя на Vercel
# ВАЖНО: Укажите БЕЗ слеша в конце!
# Пример: https://your-bot-name.vercel.app
WEBHOOK_URL=https://your-bot-name.vercel.app

# URL базы данных PostgreSQL
# Можно получить на Supabase, Neon, Railway, или Vercel Postgres
# Пример: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://user:password@host:5432/database

# Награда за реферала (опционально, по умолчанию 5.0)
REFERRAL_REWARD=5.0

# Режим отладки (опционально, по умолчанию False)
DEBUG=False
