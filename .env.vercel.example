# Пример переменных окружения для Vercel
# Эти переменные нужно добавить в Settings → Environment Variables

# Токен бота от @BotFather
BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ID администраторов (можно несколько через запятую)
# Пример: 123456789,987654321
ADMIN_CHAT_ID=123456789

# URL вашего деплоя на Vercel
# ВАЖНО: Укажите БЕЗ слеша в конце!
# Пример: https://your-bot-name.vercel.app
WEBHOOK_URL=https://nebula-two-blush.vercel.app

# URL базы данных PostgreSQL
# Можно получить на Supabase, Neon, Railway, или Vercel Postgres
# Пример: postgresql://user:password@host:5432/database
DATABASE_URL=postgresql://postgres.nndebjrieyxqjnwkslhn:[3159202177Ss]@aws-1-eu-central-1.pooler.supabase.com:6543/postgres

# Награда за реферала (опционально, по умолчанию 3.0)
REFERRAL_REWARD=3.0

# Обязательные каналы для подписки (можно несколько через запятую)
# Пример: @channel1,@channel2
REQUIRED_CHANNELS=@nebula_starsc

# ID каналов (можно несколько через запятую, должно совпадать с REQUIRED_CHANNELS)
# Получите через @userinfobot
# Пример: -1001234567890,-1009876543210
REQUIRED_CHANNEL_IDS=-1003799829820

# ID канала для рассылки новостей (по умолчанию = первый канал)
# Посты с хэштегом #новости будут автоматически рассылаться всем пользователям
NEWS_CHANNEL_ID=-1003799829820

# Режим отладки (опционально, по умолчанию False)
DEBUG=False
